# ══════════════════════════════════════════════════════════════════════════════
# VIXUAL — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier vers .env.local et remplir les valeurs.
# Ne JAMAIS commiter de clés réelles dans le dépôt.
# ══════════════════════════════════════════════════════════════════════════════

# ─── APP ───
NEXT_PUBLIC_APP_NAME=VIXUAL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# ─── ADMIN/PATRON ───
VIXUAL_ADMIN_EMAIL=jocelyndru@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=jocelyndru@gmail.com
ADMIN_ENCRYPTION_KEY=change_me_generate_secure_key

# ─── FLAGS TEST ───
NEXT_PUBLIC_USE_MOCK_AUTH=true
NEXT_PUBLIC_USE_MOCK_UPLOAD=true
NEXT_PUBLIC_USE_MOCK_VIDEO=true
VIXUAL_TEST_LAB_ENABLED=true
VIXUAL_TEST_LAB_MODE=local

# ─── Base de données (Neon) ───
DATABASE_URL=postgresql://user:pass@host/db

# ─── Authentification ───
JWT_SECRET=<generer 32+ caracteres aleatoires>

# ─── STRIPE TEST (convention officielle) ───
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# ─── STRIPE LIVE (a activer plus tard) ───
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_xxx

# ─── BUNNY.NET (desactive par defaut) ───
BUNNY_ENABLED=false
BUNNY_API_KEY=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_PULL_ZONE_URL=
BUNNY_PULL_ZONE_ID=
BUNNY_HMAC_SECRET=

# ─── Resend (emails transactionnels) ───
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@vixual.fr

# ─── Moderation ───
PATRON_EMAIL=jocelyndru@gmail.com
MODERATION_CRON_KEY=<generer 32+ caracteres aleatoires>

# ─── Security / CRON ───
BRIEFING_CRON_KEY=change_me
INTERNAL_API_SECRET=change_me

# ─── Site ───
NEXT_PUBLIC_SITE_URL=https://vixual.fr

# ─── Module Chaines createurs (V3) ───
ENABLE_CREATOR_CHANNELS=false

# ─── SOCIAL OPTIONAL ───
YOUTUBE_API_KEY=
TIKTOK_CLIENT_ID=
FACEBOOK_APP_ID=

# ─── Upstash Redis (rate limiting) ───
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# ─── Cloudflare Turnstile (challenge anti-bot, optionnel) ───
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ─── Notifications webhook (Discord / Slack / Telegram / Custom) ───
# SECURITY_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SECURITY_WEBHOOK_KIND=discord

# ─── Test Lab (DEV/STAGING UNIQUEMENT) ───
# VIXUAL_TEST_LAB_ENABLED=true
# NEXT_PUBLIC_VIXUAL_TEST_LAB_VISIBLE=true
# VIXUAL_TEST_LAB_MODE=isolated
# VIXUAL_TEST_LAB_ALLOW_REAL_STRIPE=false
# VIXUAL_TEST_LAB_ALLOW_REAL_BUNNY=false
