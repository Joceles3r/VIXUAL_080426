# ─── Base de données (Neon) ───
DATABASE_URL=postgresql://user:pass@host/db

# ─── Authentification ───
JWT_SECRET=<generer 32+ caracteres aleatoires>

# ─── Stripe (mode test pour developpement) ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Bunny.net (a configurer apres creation des zones) ───
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_ZONE_NAME=vixual-storage
BUNNY_STORAGE_REGION=de
BUNNY_CDN_HOSTNAME=vixual-storage.b-cdn.net
BUNNY_VIDEO_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_TOKEN_AUTH_KEY=
BUNNY_WEBHOOK_SECRET=
NEXT_PUBLIC_BUNNY_LIBRARY_ID=

# ─── Resend (emails transactionnels) ───
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@vixual.fr

# ─── Moderation ───
PATRON_EMAIL=jocelyndru@gmail.com
MODERATION_CRON_KEY=<generer 32+ caracteres aleatoires>

# ─── Site ───
NEXT_PUBLIC_SITE_URL=https://vixual.fr

# ─── Module Chaînes créateurs (V3) ───
# Mettre à "true" UNIQUEMENT pour activer le module en preprod/prod.
# Le toggle dans /admin/platform-state contrôle l'activation finale (double sécurité).
ENABLE_CREATOR_CHANNELS=false

# ─── Sécurité Phase 1 ───

# Upstash Redis (rate limiting déjà branché dans middleware.ts)
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# Cloudflare Turnstile (challenge anti-bot, optionnel)
# Activer en créant un site sur dash.cloudflare.com/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Notifications webhook (Discord / Slack / Telegram / Custom)
# Choisir UN canal :
# SECURITY_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SECURITY_WEBHOOK_KIND=discord       # discord | slack | telegram | custom

# OU Telegram :
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# SECURITY_WEBHOOK_KIND=telegram

# ─── Test Lab (DEV/STAGING UNIQUEMENT — NE PAS DEFINIR EN PRODUCTION) ───
# VIXUAL_TEST_LAB_ENABLED=true
# NEXT_PUBLIC_VIXUAL_TEST_LAB_VISIBLE=true
# VIXUAL_TEST_LAB_MODE=isolated
# VIXUAL_TEST_LAB_ALLOW_REAL_STRIPE=false
# VIXUAL_TEST_LAB_ALLOW_REAL_BUNNY=false
